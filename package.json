{
  "name": "@robhowley/spinner-verbs",
  "version": "3.2.1",
  "description": "Pi extension that replaces boring spinner verbs with themed alternatives that have more personality.",
  "author": "Rob Howley",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robhowley/spinner-verbs"
  },
  "homepage": "https://github.com/robhowley/spinner-verbs",
  "bugs": {
    "url": "https://github.com/robhowley/spinner-verbs/issues"
  },
  "keywords": [
    "pi-package"
  ],
  "files": [
    "extensions",
    "spinner-verbs",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "scripts": {
    "lint": "eslint extensions",
    "lint:fix": "eslint extensions --fix",
    "format:check": "prettier --check extensions",
    "format": "prettier --write extensions",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.68.0",
    "@sinclair/typebox": "^0.34.49",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  }
}
